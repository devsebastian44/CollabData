/**
 * Core Philosophy: This ruleset enforces a hybrid security model that combines strict
 * user-ownership with collaborative access for shared resources. User data is private by
 * default, while shared entities like projects are accessible to a defined list of members.
 *
 * Data Structure: The data is organized into two main structures:
 * 1. User-Scoped Collections (/users/{userId}/...): All data strictly private to a user,
 *    such as their profile, project references, and datasets, is nested under their own
 *    unique user document path. This provides strong, path-based security guarantees.
 * 2. Top-Level Shared Collections (/projects/{projectId}/...): Data intended for
 *    collaboration, such as the canonical project documents and their associated analyses,
 *    is stored in top-level collections.
 *
 * Key Security Decisions:
 * - Deny-by-Default: Access is implicitly denied unless an explicit `allow` rule grants it.
 * - No User Listing: The top-level `/users` collection is not listable to prevent enumeration of all users on the platform.
 * - Strict Ownership for Private Data: All documents and subcollections under `/users/{userId}` can only be accessed by the authenticated user matching that `userId`.
 * - Collaborative Access via Denormalization: Access to shared resources like `/projects/{projectId}` is controlled by a `userIDs` array field directly on the document. This avoids slow and costly `get()` calls in rules.
 * - Schema Dependency for Security: For collections like `/analyses`, the security model relies on the `userIDs` field being denormalized from the parent project. Where this field is missing from the documented schema, access is denied with a `TODO` to prompt the developer to fix the data model for security to function as intended. This is a secure-by-design approach.
 *
 * Denormalization for Authorization: To ensure performant and secure access control, this
 * ruleset assumes that any data needed for an authorization decision is denormalized
 * onto the document being secured. For example, the `/projects/{projectId}` document
 * contains a `userIDs` array, allowing rules to grant access to members without needing
 * to perform extra reads on other documents.
 *
 * Structural Segregation: User-private data (like project ownership records under `/users/{userId}/projects`)
 * is stored separately from the canonical shared data (the main `/projects/{projectId}` document).
 * This segregation creates a clear security boundary and improves query performance.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for reusable logic
    
    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }
    
    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Ensures a document exists before an update or delete operation.
     * This prevents state-changing requests on non-existent data.
     */
    function docExists() {
      return resource != null;
    }

    /**
     * Combines ownership check with an existence check for update/delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && docExists();
    }
    
    /**
     * Checks if the requesting user is a member of a project via its list of user IDs.
     */
    function isProjectMember(userIDs) {
      return isSignedIn() && request.auth.uid in userIDs;
    }
    
    /**
     * Checks if the requesting user is the owner of a project document.
     * This is used for write operations like updating members or deleting the project.
     */
    function isProjectOwner(projectData) {
      return isSignedIn() && request.auth.uid == projectData.ownerId;
    }

    /**
     * @description A user can create their own profile and read/update/delete it.
     * @path /users/{userId}
     * @allow A signed-in user with UID 'user123' can (create) their own profile at /users/user123.
     * @deny An anonymous user cannot (get) any user profile. A user 'userABC' cannot (update) /users/user123.
     * @principle Restricts access to a user's own data tree and enforces self-creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description A user can manage the list of projects they own.
       * @path /users/{userId}/projects/{projectId}
       * @allow User 'user123' can (create) a document at /users/user123/projects/projABC.
       * @deny User 'user456' cannot (list) documents at /users/user123/projects.
       * @principle Enforces strict ownership of all subcollection data.
       */
      match /projects/{projectId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.ownerId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description A user can manage their own datasets. Shared access is not yet implemented.
       * @path /users/{userId}/datasets/{datasetId}
       * @allow User 'user123' can (create) and (read) their own dataset at /users/user123/datasets/dataXYZ.
       * @deny User 'user456' cannot (delete) a dataset at /users/user123/datasets/dataXYZ.
       * @principle Enforces strict ownership. Shared access requires schema modification.
       * CRITICAL: The application reasoning specifies that Datasets should be accessible to project members,
       * which requires a 'userIDs' field on the Dataset document for secure, performant rules. This field is
       * missing from the Dataset entity. The current rules default to owner-only access. To enable sharing,
       * add a 'userIDs' array to the Dataset schema and update the read rules here.
       */
      match /datasets/{datasetId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Canonical project documents. Members can read; only the owner can modify or delete.
     * @path /projects/{projectId}
     * @allow A user whose UID is in the 'userIDs' array can (get) the project document. The 'ownerId' can (update) it.
     * @deny A user not in the 'userIDs' array cannot (get) the project. A member who is not the owner cannot (delete) it.
     * @principle Implements shared access using a denormalized list of collaborators.
     */
    match /projects/{projectId} {
      allow get: if isProjectMember(resource.data.userIDs);
      allow list: if false; // Listing all projects is a security risk; clients must query by user membership.
      allow create: if isSignedIn() && isProjectOwner(request.resource.data) && isProjectMember(request.resource.data.userIDs);
      allow update: if docExists() && isProjectOwner(resource.data) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if docExists() && isProjectOwner(resource.data);
      
      /**
       * @description Stores analyses for a project. Access requires project membership.
       * @path /projects/{projectId}/analyses/{analysisId}
       * @allow A user who is a member of project 'projABC' should be able to (read) an analysis within it.
       * @deny A user who is not a member of project 'projABC' should not be able to (create) an analysis.
       * @principle Inherits access control from the parent document. Blocked pending schema update.
       * CRITICAL: Cannot implement shared access rules. The 'Analysis' entity is missing a denormalized
       * 'userIDs' field from its parent Project. To enable secure access without slow `get()` calls,
       * this field must be copied to each Analysis document when it is created.
       */
      match /analyses/{analysisId} {
        allow get: if false; // TODO: Grant access if request.auth.uid is in resource.data.userIDs after updating schema.
        allow list: if false; // TODO: Grant access if request.auth.uid is in resource.data.userIDs after updating schema.
        allow create: if false; // TODO: Grant access if user is member of project and request.resource.data.userIDs is valid.
        allow update: if false; // TODO: Grant access if user is member of project.
        allow delete: if false; // TODO: Grant access if user is member (or owner) of project.
      }
    }
  }
}